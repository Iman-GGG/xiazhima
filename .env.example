# Copy this file to .env.local for local development.
# Never commit real passwords, tokens, or production values.

# Required to enable the administrator login.
ADMIN_PASSWORD=

# Required to sign administrator session cookies.
# Generate a high-entropy value, for example: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Optional: authorize POST /api/precompute with x-precompute-secret.
PRECOMPUTE_SECRET=

# Optional: remote KV cache. Leave both empty to use local cache behavior.
KV_REST_API_URL=
KV_REST_API_TOKEN=
